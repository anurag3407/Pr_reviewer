# ─────────────────────────────────────────────────────────────────────────────
# Autoheal — multi-tenant AI PR review. Copy to .env.local and fill in.
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth: Clerk ──────────────────────────────────────────────────────────────
# Dev works in "keyless" mode automatically (keys auto-loaded from .clerk/.tmp).
# For a real instance, claim the app and set these:
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── State: live Lemma pod ────────────────────────────────────────────────────
# Get a token with `lemma auth login` (it EXPIRES — refresh when reviews stall)
# and a pod id from `lemma pod create`. Then run `npm run lemma:setup`.
LEMMA_API_URL=https://api.lemma.work
LEMMA_AUTH_URL=https://lemma.work/auth
LEMMA_POD_ID=
LEMMA_TOKEN=

# ── Model: MiMo-V2.5-Pro via Bynara (OpenAI-compatible) ──────────────────────
# 1M-context reasoning model that does the reviews / chat / fixes.
BYNARA_API_KEY=sk-nry-yHAyIBdCZ7J1l71DURXfFqPAhG062AUX2-bWf6lxJT8
BYNARA_BASE_URL=https://router.bynara.id/v1
REVIEW_MODEL=mimo-v2.5-pro-free
# Optional Anthropic fallback (used only if BYNARA_API_KEY is unset):
ANTHROPIC_API_KEY=
FALLBACK_MODEL=claude-opus-4-8

# ── Repo access: GitHub App ──────────────────────────────────────────────────
# Register a GitHub App (see README). Permissions: Pull requests R/W, Contents
# R/W, Metadata R. Subscribe to: Pull request, Installation. Setup URL:
#   <APP_URL>/api/github/setup     Webhook URL: <APP_URL>/api/webhooks/github
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=          # PEM; single-line with \n escapes is fine
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_SLUG=                 # the app's URL slug (github.com/apps/<slug>)
GITHUB_WEBHOOK_SECRET=

# ── Review tuning ────────────────────────────────────────────────────────────
CONTEXT_TOKEN_BUDGET=300000      # how much context to pack (MiMo window ~1M)
CONTEXT_MAX_DEP_FILES=40         # first-order dependency files to include
MAX_FIX_ITERS=4                  # fix→re-scan attempts before handing to a human
POST_GITHUB_REVIEWS=             # set to 1 to also post findings as PR comments

# ── Local dev / demo ─────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
# scripts/simulate-pr.ts (trigger a review for a connected repo + open PR):
SIM_REPO=
SIM_INSTALLATION_ID=
SIM_PR_NUMBER=
SIM_BASE=main
