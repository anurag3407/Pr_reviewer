# ── Lemma (live pod — the state layer) ──────────────────────────────────────
# The state memory is a real Lemma pod. Get a token with `lemma auth login`
# (or a service token) and a pod id from `lemma pod create`.
LEMMA_API_URL=https://api.lemma.work
LEMMA_AUTH_URL=https://lemma.work/auth
LEMMA_POD_ID=
LEMMA_TOKEN=

# ── Tester (decision #3: pluggable runner) ──────────────────────────────────
# mock (default) | npm | testsprite
TEST_RUNNER=mock
# Fail every attempt — demos the 5/5 human-approval gate (mock runner only).
FORCE_FAIL=0
# Real TestSprite path needs a created test id and a PUBLIC preview URL
# (it rejects localhost — use a Vercel preview or ngrok).
TESTSPRITE_API_KEY=
TESTSPRITE_TEST_ID=

# ── LLM provider (agents + fixer) ───────────────────────────────────────────
# Order: Bynara (free, OpenAI-compatible) → Anthropic → deterministic fallback.
# NOTE: the two providers take DIFFERENT model ids — keep them on separate vars.
BYNARA_API_KEY=
BYNARA_MODEL=mimo-v2.5-pro-free   # model id Bynara understands
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
FIXER_MODEL=claude-opus-4-8       # legacy alias for ANTHROPIC_MODEL (v1 fixer)

# ── GitHub (v2: real PR ingestion) ──────────────────────────────────────────
# real (default when GITHUB_TOKEN is set) | mock (reads fixtures/sample-pr.json).
GITHUB_MODE=real
# Fine-grained PAT — scopes: Pull requests (read+write), Contents (read).
# Create at https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=
# Set the SAME value in the repo webhook settings (Phase 1 webhook path).
GITHUB_WEBHOOK_SECRET=

# ── Outbound notify (optional) ──────────────────────────────────────────────
# Slack incoming webhook URL; unset → notify is a no-op (logged only).
SLACK_WEBHOOK_URL=

# ── Legacy git push (v1 auto-heal; mock by default) ─────────────────────────
# mock (default) | real. Real mode only touches GIT_REPO_DIR, never this repo.
GIT_MODE=mock
GIT_REPO_DIR=

# ── Loop pacing / demo ──────────────────────────────────────────────────────
# Pause between heal attempts (ms) so the dashboard shows the transitions.
LOOP_STEP_DELAY_MS=1200
# Used by scripts/simulate-pr.ts when the app isn't on the default port.
APP_URL=http://localhost:3000

BYNARA_API_KEY=sk-nry-yHAyIBdCZ7J1l71DURXfFqPAhG062AUX2-bWf6lxJT8