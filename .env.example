# ── Lemma (live pod — the state layer) ──────────────────────────────────────
# The state memory is a real Lemma pod. Get a token with `lemma auth login`
# (or a service token) and a pod id from `lemma pod create`.
LEMMA_API_URL=https://api.lemma.work
LEMMA_AUTH_URL=https://lemma.work/auth
LEMMA_POD_ID=
LEMMA_TOKEN=

# ── Tester (decision #3: pluggable runner) ──────────────────────────────────
# mock (default) | npm | testsprite
TEST_RUNNER=mock
# Fail every attempt — demos the 5/5 human-approval gate (mock runner only).
FORCE_FAIL=0
# Real TestSprite path needs a created test id and a PUBLIC preview URL
# (it rejects localhost — use a Vercel preview or ngrok).
TESTSPRITE_API_KEY=
TESTSPRITE_TEST_ID=

# ── Fixer (Claude) ──────────────────────────────────────────────────────────
# Unset → the fixer uses a deterministic mock so the loop always advances.
ANTHROPIC_API_KEY=
FIXER_MODEL=claude-opus-4-8

# ── Git push (brief: mock by default) ───────────────────────────────────────
# mock (default) | real. Real mode only touches GIT_REPO_DIR, never this repo.
GIT_MODE=mock
GIT_REPO_DIR=
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# ── Loop pacing / demo ──────────────────────────────────────────────────────
# Pause between heal attempts (ms) so the dashboard shows the transitions.
LOOP_STEP_DELAY_MS=1200
# Used by scripts/simulate-pr.ts when the app isn't on the default port.
APP_URL=http://localhost:3000
